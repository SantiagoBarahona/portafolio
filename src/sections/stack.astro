---
import Card from '@components/Card.astro'
import HTML5 from '@icons/HTML5.astro'
import CSS from '@icons/CSS.astro'
import JavaScript from '@icons/JavaScript.astro'
import React from '@icons/React.astro'
import Tailwind from '@icons/Tailwind.astro'
import Node from '@icons/Node.astro'
import Express from '@icons/Express.astro'
import AstroIcon from '@icons/AstroIcon.astro'
import Next from '@icons/Next.astro'
import Postgres from '@icons/Postgres.astro'
import Github from '@icons/Github.astro'
import Git from '@icons/Git.astro'
import Neon from '@icons/Neon.astro'
import Figma from '@icons/Figma.astro'
import Java from '@icons/Java.astro'
import Python from '@icons/Python.astro'
---

<section id="stack">
  <div class="section-header">
    <h1 class="section-title font-[Bebas_Neue]">Tecnologías</h1>
    <div class="section-line"></div>
  </div>

  <div class="grid sm:grid-cols-2 gap-5 [&>article]:w-full">
    <Card title="Frontend">
      <div slot="content" class="tech-grid">
        <span class="tech-item"><HTML5 />HTML</span>
        <span class="tech-item"><CSS />CSS</span>
        <span class="tech-item"><JavaScript />JavaScript</span>
        <span class="tech-item"><React />React</span>
        <span class="tech-item"><Tailwind />Tailwind</span>
        <span class="tech-item"><Figma />Figma</span>
      </div>
    </Card>

    <Card title="Backend">
      <div slot="content" class="tech-grid">
        <span class="tech-item"><Node />NodeJs</span>
        <span class="tech-item"><AstroIcon />Astro</span>
        <span class="tech-item"><Next />Next</span>
        <span class="tech-item"><Postgres width={24} height={24} />Postgres</span>
        <span class="tech-item"><Express />ExpressJs</span>
        <span class="tech-item"><Neon />Neon</span>
      </div>
    </Card>

    <Card title="Herramientas">
      <div slot="content" class="tech-grid">
        <span class="tech-item"><Git />Git</span>
        <span class="tech-item"><Github />GitHub</span>
      </div>
    </Card>

    <Card title="Otros lenguajes">
      <div slot="content" class="tech-grid">
        <span class="tech-item"><Java />Java</span>
        <span class="tech-item"><Python />Python</span>
      </div>
    </Card>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    color: white;
    font-size: 3rem;
    letter-spacing: 0.03em;
    line-height: 1;
  }

  .section-line {
    width: 2.5rem;
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
    margin-top: 0.5rem;
    opacity: 0.8;
  }

  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
    padding: 0.6rem 0.8rem;
    cursor: default;
  }
</style>

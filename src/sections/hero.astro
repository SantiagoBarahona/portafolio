---
import Button from '@components/Button.astro'
import Contacts from '@components/Contacts.astro'
---

<section id="hero" class="text-white flex gap-10 items-center pt-28 md:pt-36">
  <div class="relative hidden md:block shrink-0">
    <div class="avatar-glow absolute inset-0 rounded-full"></div>
    <img
      src="/santiago.webp"
      alt="Retrato de Santiago Zapata Barahona"
      class="relative w-[260px] h-[260px] aspect-square rounded-full object-cover object-center"
      style="border: 1px solid rgba(59,130,246,0.25); box-shadow: 0 0 40px rgba(59,130,246,0.15), 0 8px 32px rgba(0,0,0,0.6);"
    />
  </div>

  <div class="flex flex-col gap-5 animate-fade-up">
    <hgroup>
      <p class="text-[var(--text-secondary)] text-base tracking-widest uppercase mb-1 font-[Bebas_Neue]">
        ¡Hola! me llamo
      </p>
      <h1 class="text-7xl lg:text-8xl font-[Bebas_Neue] leading-none text-blue-600 text-balance">
        Santiago Zapata Barahona
      </h1>
    </hgroup>

    <h2 class="text-xl text-slate-400 tracking-wide">
      Full Stack Developer
    </h2>

    <Contacts />

    <div class="flex flex-wrap gap-3 items-center">
      <Button href="/#about">Conoce más sobre mí</Button>
    </div>
  </div>
</section>

<style>
.avatar-glow {
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.25) 0%,
      transparent 70%
    );
    transform: scale(1.2);
    filter: blur(20px);
  }

  section {
    opacity: 0;
    animation: fadeUp 0.8s ease-out 0.1s forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

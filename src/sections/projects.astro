---
import { getCollection } from 'astro:content'
import Card from '../components/Card.astro'
import Chip from '../components/Chip.astro'
import Icon from '../components/Icon.astro'
import OpenInNew from '../icons/OpenInNew.astro'
import Github from '../icons/Github.astro'
import SocialChip from '@components/SocialChip.astro'

const projects = await getCollection('projects')
---

<section id="projects" class="w-full">
  <div class="section-header">
    <h1 class="section-title font-[Bebas_Neue]">Proyectos</h1>
    <div class="section-line"></div>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    {
      projects.map((project) => (
        <Card
          title={project.data.title}
          description={project.data.description}
        >
          {project.data.github && (
            <SocialChip
              href={project.data.github}
              slot="after-title"
              class="ml-auto text-xs"
            >
              <Github /> GitHub
            </SocialChip>
          )}
          <div slot="image">
            {project.data.videoSrc ? (
              <video
                class="project-video w-full block"
                src={project.data.videoSrc}
                controls
                playsinline
              />
            ) : project.data.href ? (
              <a class="project-link w-full h-fit relative block overflow-hidden" href={project.data.href}>
                <div class="project-overlay absolute w-full h-full top-0 flex justify-center items-center">
                  <div class="project-icon">
                    <OpenInNew />
                  </div>
                </div>
                <img
                  class="project-img"
                  src={project.data.imgSrc}
                  alt={`${project.data.title} preview`}
                />
              </a>
            ) : (
              <img
                class="project-img-static"
                src={project.data.imgSrc}
                alt={`${project.data.title} preview`}
              />
            )}
          </div>
          <div slot="footer" class="flex flex-wrap gap-2 pt-1">
            {project.data.stack.map((label) => (
              <Chip>
                <Icon name={label} />
                {label}
              </Chip>
            ))}
          </div>
        </Card>
      ))
    }
  </div>
</section>

<style>
  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    color: white;
    font-size: 3rem;
    letter-spacing: 0.03em;
    line-height: 1;
  }

  .section-line {
    width: 2.5rem;
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
    margin-top: 0.5rem;
    opacity: 0.8;
  }

  .project-overlay {
    z-index: 1;
    background-color: rgba(0, 0, 0, 0.55);
    transition: background-color 0.25s ease;
  }

  .project-icon {
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .project-link:hover .project-overlay {
    background-color: rgba(0, 0, 0, 0.25);
  }

  .project-link:hover .project-icon {
    opacity: 1;
    transform: scale(1);
  }

  .project-img {
    z-index: 0;
    display: block;
    width: 100%;
    transition: transform 0.35s ease;
  }

  .project-link:hover .project-img {
    transform: scale(1.06);
  }

  .project-img-static {
    display: block;
    width: 100%;
  }

  .project-video {
    display: block;
    width: 100%;
    object-fit: cover;
  }
</style>

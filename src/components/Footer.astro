---
import Mail from '@icons/Mail.astro'
---

<footer class="footer-wrap text-white mt-4">
  <div class="footer-inner px-6 md:px-16 py-10 max-w-[1000px] mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <p class="font-[Bebas_Neue] text-3xl tracking-widest text-blue-400 mb-1">SZ</p>
        <p class="text-[var(--text-secondary)] text-sm">Santiago Zapata Barahona</p>
        <p class="text-[var(--text-secondary)] text-xs mt-0.5">Full Stack Developer · Medellín, Colombia</p>
      </div>

      <div class="flex flex-col gap-2">
        <p class="font-[Bebas_Neue] text-lg tracking-wider text-[var(--text-secondary)]">Contáctame</p>
        <a
          href="mailto:llsanthiago@gmail.com"
          class="contact-link flex gap-2 items-center text-sm text-[var(--text-secondary)] hover:text-white"
        >
          <Mail /> llsanthiago@gmail.com
        </a>
      </div>
    </div>

    <div class="footer-divider mt-8 mb-4"></div>

    <p class="text-center text-xs text-[var(--text-secondary)] opacity-50">
      Hecho con dedicación por Santiago Zapata Barahona 🤓
    </p>
  </div>
</footer>

<style>
  .footer-wrap {
    border-top: 1px solid var(--border);
    background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.3));
  }

  .footer-divider {
    height: 1px;
    background: var(--border);
  }

  .contact-link {
    transition: color 0.2s ease;
  }
</style>

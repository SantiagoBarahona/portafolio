---
const links = [
  {
    label: 'Inicio',
    href: '/#hero',
  },
  {
    label: 'Proyectos',
    href: '/#projects',
  },
  {
    label: 'Conóceme',
    href: '/#about',
  },
  {
    label: 'Tecnologías',
    href: '/#stack',
  },
]
---

<nav
  class="fixed top-0 z-10 w-screen py-3 text-white font-[Bebas_Neue] text-xl"
>
  <div class="flex items-center px-6 md:px-16 max-w-[1000px] mx-auto">
    <a href="/#hero" class="brand-mark mr-auto text-2xl tracking-widest text-blue-400 hover:text-blue-300 transition-colors duration-200">
      SZ
    </a>
    <ul class="flex gap-1">
      {
        links.map((link) => (
          <li>
            <a
              class="nav-link px-3 py-1 rounded-md text-white/40 hover:text-white transition-colors duration-150 hover:ease-in ease-out navbar-link"
              id={link.href}
              href={link.href}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  nav {
    animation: scrollDown both;
    animation-timeline: scroll();
    animation-range: entry 1% cover 5%;
  }

  @keyframes scrollDown {
    to {
      background-color: rgba(7, 8, 12, 0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
  }

  .nav-link {
    position: relative;
    letter-spacing: 0.05em;
  }

  .nav-link.active {
    color: white;
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--accent);
  }

  .brand-mark {
    letter-spacing: 0.15em;
    font-size: 1.4rem;
  }
</style>

<script>
  const links = document.querySelectorAll('.navbar-link')
  const setActiveLink = (activeRoute: string) => {
    links.forEach((link) => {
      if (link.id == activeRoute) link.classList.add('active')
      else link.classList.remove('active')
    })
  }
  let fullLocation = `${location.pathname}${location.hash}`
  setActiveLink(fullLocation)
  window.addEventListener('hashchange', () => {
    setActiveLink(`${location.pathname}${location.hash}`)
  })
</script>

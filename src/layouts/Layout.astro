---
import Footer from '@components/Footer.astro'
import Navbar from '@components/Navbar.astro'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Portafolio de Santiago Zapata Barahona, full stack developer."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/s-logo.webp" />
    <meta name="generator" content={Astro.generator} />
    <title>Santiago Zapata Barahona</title>
  </head>
  <body class="antialiased relative">
    <!-- Base background -->
    <div class="fixed inset-0 -z-30 bg-[#07080c]"></div>
    <!-- Subtle grid -->
    <div
      class="fixed inset-0 -z-20 bg-[linear-gradient(to_right,#ffffff06_1px,transparent_1px),linear-gradient(to_bottom,#ffffff06_1px,transparent_1px)] bg-[size:32px_32px]"
    >
    </div>
    <!-- Top glow accent -->
    <div
      class="fixed top-0 left-0 right-0 -z-10 h-[500px] bg-[radial-gradient(ellipse_70%_40%_at_50%_0%,rgba(37,99,235,0.12),transparent)]"
    >
    </div>
    <header>
      <Navbar />
    </header>
    <main
      class="[&>section]:px-6 [&>section]:md:px-16 [&>section]:py-20 [&>section]:max-w-[1000px] [&>section]:mx-auto"
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  @import 'tailwindcss';

  :root {
    --accent: #3b82f6;
    --accent-dim: rgba(59, 130, 246, 0.12);
    --accent-glow: rgba(59, 130, 246, 0.3);
    --surface: rgba(255, 255, 255, 0.03);
    --surface-hover: rgba(255, 255, 255, 0.06);
    --border: rgba(255, 255, 255, 0.07);
    --border-accent: rgba(59, 130, 246, 0.25);
    --text-primary: #f0f4ff;
    --text-secondary: #8892a4;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    font-family: 'Inter', sans-serif;
    color: var(--text-primary);
    background-color: #07080c;
    box-sizing: border-box;
    scroll-behavior: smooth;
  }

  @font-face {
    font-family: 'Inter';
    src: url('/fonts/Inter/Inter_18pt-Regular.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Bebas Neue';
    src: url('/fonts/Bebas_Neue/BebasNeue-Regular.woff2') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-fade-up {
    animation: fadeUp 0.7s ease-out forwards;
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }
</style>
